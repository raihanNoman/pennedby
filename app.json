{
  "expo": {
    "name": "pen",
    "slug": "pen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pen",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "appleTeamId": "759G3V6R99",
      "bundleIdentifier": "com.nomanapps21.pennedbyme",
      "associatedDomains": ["applinks:app.quran600.com"],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Used to record Quran recitation for pronunciation feedback and practice.",
        "NSSpeechRecognitionUsageDescription": "Used to convert arabic speech into text for recitation practice and tests.",
        "NSFaceIDUsageDescription": "Allow Quran600 to use Face ID for automatic login and subscription management.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.nomanapps21.pennedbyme",
      "permissions": [
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE"
      ],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Used to record Quran recitation for pronunciation feedback and practice."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
